{
  "name": "alive-interface",
  "version": "0.1.0",
  "description": "User-facing interface for ALIVE. Provides visibility, controls, audit views, and state inspection.",
  "main": "dist/index.js",
  "workspaces": [
    "packages/shared-types",
    "packages/runtime-client",
    "plugins/alive-launcher",
    "plugins/alive-trace",
    "plugins/alive-signals",
    "plugins/alive-state",
    "plugins/alive-logs",
    "theia-app"
  ],
  "scripts": {
    "build": "tsc",
    "check:backbone": "node scripts/backbone-freeze-check.mjs",
    "demo:start": "npm --prefix ../alive-runtime run start",
    "demo:studio": "npm --prefix studio/dashboard run dev",
    "demo:trigger": "npm --prefix ../alive-runtime run phase1:prove",
    "demo:inspect": "node scripts/demo-inspect.mjs",
    "demo:reset": "node scripts/demo-reset.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
