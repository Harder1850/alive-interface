{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "outDir":          "dist/server",
    "rootDir":         "src/server",
    "strict":          true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck":    true
  },
  "include": ["src/server/**/*.ts"]
}
